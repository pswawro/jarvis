# AWS Credentials (optional — leave empty to fall back on default credential chain,
# e.g. IAM role, ~/.aws/credentials, or environment variables set by the runtime)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# LLM Assistant (Bedrock)
LLM_AWS_REGION=eu-west-1
LLM_MODEL_ID=eu.anthropic.claude-sonnet-4-6
LLM_MODEL_ID_HEAVY=eu.anthropic.claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_MAX_ITERATIONS=10
LLM_TEMPERATURE=0.1
LLM_DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Push Insights
INSIGHT_SENSITIVITY=medium
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com
