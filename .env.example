# AWS Credentials (optional — leave empty to fall back on default credential chain,
# e.g. IAM role, ~/.aws/credentials, or environment variables set by the runtime)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# LLM Assistant (Bedrock)
LLM_AWS_REGION=eu-west-1
LLM_MODEL_ID=eu.anthropic.claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_MAX_ITERATIONS=10

# Server
HOST=0.0.0.0
PORT=8000
